# ============================================================
# Database
# ============================================================
DATABASE_URL=sqlite:///./bi_dashboard.db

# Supabase PostgreSQL examples. Replace placeholders locally before use.
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0.us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
# DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# ============================================================
# Supabase REST API
# ============================================================
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=
SUPABASE_DB_PASSWORD=

# Data backend: "sqlite" | "supabase"
DB_BACKEND=sqlite

# Redis
REDIS_URL=redis://localhost:6379/0
USE_REDIS=false

# JWT
SECRET_KEY=change-me-local-dev-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5174

# Scheduler
ENABLE_SCHEDULER=true
DAILY_SUMMARY_HOUR=2
DAILY_SUMMARY_MINUTE=0

# Yingdao RPA platform. Replace token locally before use.
YINGDAO_TOKEN=
YINGDAO_UPLOAD_URL=https://power-api.yingdao.com/oapi/power/v1/file/upload
YINGDAO_FLOW_URL=https://power-api.yingdao.com/oapi/power/v1/rest/flow/<flow-id>/execute
YINGDAO_FLOW_ASYNC_URL=https://power-api.yingdao.com/oapi/power/v1/rest/flow/<flow-id>/execute/async
YINGDAO_RESULT_URL=https://power-api.yingdao.com/oapi/power/v1/rest/flow/execute/result
YINGDAO_TIMEOUT=60
